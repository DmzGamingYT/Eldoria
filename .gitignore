# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production (Next.js output is in .next/, electron output in dist-electron/)

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
.zscripts/dev.out
.zscripts/dev.pid

# Skills directory
/skills/

# Electron build output
dist-electron/
out/

# Prisma database (local dev only)
db/*.db
prisma/db/*.db

# npm lockfile (projet utilise Bun)
package-lock.json

# Build (artefacts de debug oubliés lors du travail sur le set d'icônes —
# ne JAMAIS les committer, ils servent juste aux tests manuels locaux).
build/*.bak
build/icon_test.ico

# Temp directory (scripts de debug release, PR drafts, logs CI)
tmp/

# Cover PNG + screenshots préparés pour l'upload itch.io (scripts/render-itch-cover.mjs).
# On n'ignore que le sous-dossier release/ racine du projet, pas docs/release/.
/release/
/release/**/*.png
# Internal dev journal (not for public repo)
worklog.md

# SVG optimizer transient backups (scripts/optimize-svgs.mjs --backup)
*.svg.bak
