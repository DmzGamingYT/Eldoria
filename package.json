{
  "name": "eldoria",
  "version": "0.2.4",
  "private": true,
  "main": "electron/main.js",
  "description": "Eldoria — un RPG fantasy 3D jouable dans le navigateur et installable sur Windows, macOS et Linux. Monde procédural, combat en temps réel, 5 sorts, 6 ennemis + boss, 5 quêtes.",
  "author": {
    "name": "DmzGamingYT",
    "email": "innangialessio@gmail.com"
  },
  "homepage": "https://github.com/DmzGamingYT/Eldoria",
  "desktopName": "Eldoria",
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build && bun scripts/copy-standalone-assets.mjs",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "electron:dev": "concurrently -k \"bun dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "bun run db:generate && bun run build && electron-builder --publish never",
    "electron:build:win": "bun run db:generate && bun run build && electron-builder --win --publish never",
    "electron:build:mac": "bun run db:generate && bun run build && electron-builder --mac --publish never",
    "electron:build:linux": "bun run db:generate && bun run build && electron-builder --linux --publish never",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "trailer": "node scripts/capture-trailer.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
