{
  "name": "eldoria",
  "version": "0.4.1",
  "private": true,
  "main": "electron/main.js",
  "description": "Eldoria — un RPG fantasy 3D jouable dans le navigateur et installable sur Windows, macOS et Linux. Monde procédural, combat en temps réel, 5 sorts, 6 ennemis + boss, 5 quêtes.",
  "author": {
    "name": "DmzGamingYT",
    "email": "innangialessio@gmail.com"
  },
  "homepage": "https://github.com/DmzGamingYT/Eldoria",
  "desktopName": "Eldoria",
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build && bun scripts/copy-standalone-assets.mjs",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "electron:dev": "concurrently -k \"bun dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "bun run build && electron-builder --publish never",
    "electron:build:win": "bun run build && electron-builder --win --publish never",
    "electron:build:mac": "bun run build && electron-builder --mac --publish never",
    "electron:build:linux": "bun run build && electron-builder --linux --publish never",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "trailer": "node scripts/capture-trailer.mjs",
    "build:demo": "node scripts/build-demo-gif.mjs",
    "social-card": "node scripts/generate-social-card.mjs",
    "optimize:screenshots": "node scripts/optimize-screenshots.mjs",
    "optimize:svgs": "bun scripts/optimize-svgs.mjs",
    "optimize:svgs:dry": "bun scripts/optimize-svgs.mjs --dry-run"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "bun-types": "^1.3.14",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "playwright": "^1.61.1",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "lodash": "^4.17.21",
    "defu": "^6.1.5",
    "diff": "^5.2.2",
    "effect": "^3.20.0",
    "flatted": "^3.4.2",
    "js-yaml": "^4.2.0",
    "postcss": "^8.5.10"
  }
}
